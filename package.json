{
  "name": "agent-ledger",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@tsconfig/bun": "^1.0.9",
    "@types/bun": "latest",
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "bun run --cwd apps/tui dev",
    "snapshot": "bun run --cwd packages/service snapshot",
    "typecheck": "tsc -p packages/service/tsconfig.json --noEmit && tsc -p apps/tui/tsconfig.json --noEmit && tsc -p tsconfig.json --noEmit",
    "build:release": "bun run script/build.ts",
    "release:version": "bun run script/version.ts",
    "release:publish": "bun run script/publish.ts"
  }
}
